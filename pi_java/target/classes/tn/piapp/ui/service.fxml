<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.piapp.ui.ServiceController"
      spacing="0" style="-fx-background-color: #F6F7FB;">

    <!-- Toolbar row -->
    <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 16 20 12 20;">
        <Button fx:id="btnAdd" text="+ Add Service" styleClass="btn-add" onAction="#onAdd"/>
        <Button fx:id="btnEdit" text="Edit" styleClass="btn-edit" onAction="#onEdit"/>
        <Button fx:id="btnDelete" text="Delete" styleClass="btn-delete" onAction="#onDelete"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="tfSearch" promptText="🔍  Search services..." styleClass="search-field"/>
        <ProgressIndicator fx:id="progressIndicator" prefWidth="24" prefHeight="24"/>
        <Button fx:id="btnRefresh" text="↻ Refresh" styleClass="btn-refresh" onAction="#onRefresh"/>
    </HBox>

    <!-- Filter bar: approval toggle + advanced filters + clear button -->
    <HBox fx:id="filterBar" spacing="10" alignment="CENTER_LEFT"
          style="-fx-padding: 0 20 10 20; -fx-background-color: white;
                 -fx-border-color: #E6E8EF; -fx-border-width: 0 0 1 0;">
        <!-- Approval toggle -->
        <Label text="Show:" styleClass="filter-label"/>
        <RadioButton fx:id="rbAll" text="All" styleClass="filter-radio"/>
        <RadioButton fx:id="rbActiveOnly" text="Active" styleClass="filter-radio"/>
        <RadioButton fx:id="rbPending" text="Pending" styleClass="filter-radio"/>

        <Separator orientation="VERTICAL" style="-fx-padding: 4 4 4 4;"/>

        <!-- Category filter -->
        <Label text="Category:" styleClass="filter-label"/>
        <ComboBox fx:id="cbCategoryFilter" promptText="All Categories"
                  prefWidth="140" styleClass="filter-combo"/>

        <!-- Location filter -->
        <Label text="Location:" styleClass="filter-label"/>
        <TextField fx:id="tfLocationFilter" promptText="Any location"
                   prefWidth="110" styleClass="filter-field"/>

        <!-- Price range -->
        <Label text="Price:" styleClass="filter-label"/>
        <TextField fx:id="tfMinPrice" promptText="Min" prefWidth="60" styleClass="filter-field"/>
        <Label text="–" styleClass="filter-label"/>
        <TextField fx:id="tfMaxPrice" promptText="Max" prefWidth="60" styleClass="filter-field"/>

        <!-- Sort -->
        <Label text="Sort:" styleClass="filter-label"/>
        <ComboBox fx:id="cbSortBy" prefWidth="160" styleClass="filter-combo"/>

        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnClearFilters" text="✕ Clear" styleClass="btn-refresh" onAction="#onClearFilters"/>
    </HBox>

    <!-- Card wrapping the TableView -->
    <VBox VBox.vgrow="ALWAYS" styleClass="card"
          style="-fx-margin: 0 20 0 20;">
        <padding>
            <Insets top="0" right="20" bottom="0" left="20"/>
        </padding>
        <TableView fx:id="tableView" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: transparent; -fx-border-width: 0;">
            <columns>
                <TableColumn fx:id="colName" text="NAME" prefWidth="130"/>
                <TableColumn fx:id="colDescription" text="DESCRIPTION" prefWidth="160"/>
                <TableColumn fx:id="colBasePrice" text="BASE PRICE" prefWidth="85"/>
                <TableColumn fx:id="colDurationMinutes" text="DURATION (MIN)" prefWidth="105"/>
                <TableColumn fx:id="colLocation" text="LOCATION" prefWidth="100"/>
                <TableColumn fx:id="colIsActive" text="STATUS" prefWidth="75"/>
                <TableColumn fx:id="colImageName" text="IMAGE" prefWidth="90"/>
            </columns>
        </TableView>
    </VBox>

    <!-- Status bar -->
    <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="8" VBox.vgrow="NEVER">
        <Label fx:id="lblStatus" text="Ready" styleClass="status-label"/>
    </HBox>

</VBox>
